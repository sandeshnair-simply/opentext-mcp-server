# OpenText Content Server — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Base URL of your Content Server instance
# Must end at /cs/cs — do NOT append /api/v1/auth
OT_BASE_URL=https://your-ot-instance.com/cs/cs

# REST API v2 base path (auto-derived from OT_BASE_URL if not set)
OT_API_BASE=https://your-ot-instance.com/cs/cs/api/v2

# Content Server credentials
OT_USERNAME=your_username
OT_PASSWORD=your_password
